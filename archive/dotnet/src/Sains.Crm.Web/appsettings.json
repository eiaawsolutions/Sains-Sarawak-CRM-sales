{
  "ConnectionStrings": {
    "Crm": "Server=localhost;Database=SainsCrm;Integrated Security=true;TrustServerCertificate=true;Encrypt=true;"
  },
  "Fim": {
    "Authority": "https://fim2.sarawak.gov.my",
    "ClientId": "SET-IN-USER-SECRETS",
    "ClientSecret": "SET-IN-USER-SECRETS",
    "CallbackPath": "/auth/fim/callback",
    "SignedOutCallbackPath": "/auth/fim/signed-out",
    "Scopes": "openid email cn mobile",
    "UsePkce": true
  },
  "SmartXChange": {
    "TokenEndpoint": "https://apitnt.sains.com.my/token",
    "QueryEndpoint": "https://apitnt.sains.com.my/ldapquery/v1.0/users/email/query",
    "ConsumerKey": "SET-IN-USER-SECRETS",
    "ConsumerSecret": "SET-IN-USER-SECRETS",
    "HttpTimeoutSeconds": 10
  },
  "CmdWebhook": {
    "ClientId": "SET-IN-USER-SECRETS",
    "SecretKey": "SET-IN-USER-SECRETS",
    "AccessToken": "SET-IN-USER-SECRETS",
    "TimestampWindowMs": 300000,
    "MaxBodyBytes": 524288
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "HttpStatusCode": 429,
    "GeneralRules": [
      { "Endpoint": "post:/auth/*",                       "Period": "5m", "Limit": 10 },
      { "Endpoint": "post:/api/CommonService.svc/SaveXml/*", "Period": "1s", "Limit": 100 },
      { "Endpoint": "*",                                  "Period": "1m", "Limit": 600 }
    ]
  },
  "Uat": {
    "SeedPath": "db/testdata/uat_cases.json",
    "SelfBaseUrl": "http://localhost:5000"
  },
  "Storage": {
    "QuotationPdfRoot": "D:/storage/crm/quotations"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": { "Default": "Information" }
  },
  "AllowedHosts": "*"
}
