{
  "name": "sains-crm-web",
  "version": "1.0.0",
  "private": true,
  "description": "SAINS Sarawak CRM — Next.js on Railway (Claritas × EIAAW Solutions)",
  "scripts": {
    "dev": "node scripts/bundle-docs.mjs && next dev -p 3000",
    "build": "node scripts/bundle-docs.mjs && next build",
    "start": "next start -p ${PORT:-3000}",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed:uat": "tsx src/db/seed-uat.ts",
    "db:seed:test-user": "tsx src/db/seed-test-user.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "1.0.6",
    "@anthropic-ai/sdk": "0.32.1",
    "@auth/core": "0.37.3",
    "@auth/drizzle-adapter": "1.7.3",
    "@radix-ui/react-dialog": "1.1.2",
    "@radix-ui/react-dropdown-menu": "2.1.2",
    "@radix-ui/react-label": "2.1.0",
    "@radix-ui/react-select": "2.1.2",
    "@radix-ui/react-slot": "1.1.0",
    "@radix-ui/react-tabs": "1.1.1",
    "@radix-ui/react-tooltip": "1.1.4",
    "@react-pdf/renderer": "4.1.5",
    "@tanstack/react-query": "5.62.7",
    "ai": "4.0.18",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "0.36.4",
    "inngest": "3.27.4",
    "lucide-react": "0.468.0",
    "next": "15.5.9",
    "next-auth": "5.0.0-beta.25",
    "pino": "9.5.0",
    "pino-pretty": "11.3.0",
    "postgres": "3.4.5",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tailwind-merge": "2.5.5",
    "xlsx": "0.18.5",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "22.10.2",
    "@types/react": "19.0.1",
    "@types/react-dom": "19.0.2",
    "@vitest/ui": "2.1.8",
    "autoprefixer": "10.4.20",
    "drizzle-kit": "0.30.1",
    "eslint": "9.17.0",
    "eslint-config-next": "15.5.9",
    "postcss": "8.4.49",
    "tailwindcss": "3.4.17",
    "tsx": "4.19.2",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
